# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Temperatura del LLM (router + compositor), 0.0–2.0
LLM_TEMPERATURE=0

# Rutas a datos (relativas a la raíz del proyecto `project/`)
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_INDEXES_DIR=./data/indexes

# SQLite (reseñas desde Excel)
SQLITE_DB_PATH=./data/processed/bank_reviews.sqlite
# Excel fuente: al arrancar FastAPI, si SQLite está vacío se ingiere automáticamente.
# Si esta ruta no existe, se busca un .xlsx en data/docs y data/raw (p. ej. bank_reviews_colombia (1).xlsx).
REVIEWS_EXCEL_PATH=./data/raw/bank_reviews_colombia.xlsx

# Catálogo JSON de productos (p. ej. generado con build_products_catalog desde PDF)
PRODUCT_CATALOG_PATH=./data/processed/products_catalog.json

# RAG BRE-B: índice FAISS (generar con storage.faiss_index.build_breb_index)
BREB_FAISS_INDEX_DIR=./data/vectorstore/breb_index
# PDF de entrada para build_breb_index (opcional si no usas la ruta por defecto en data/docs/)
# BREB_PDF_PATH=./data/docs/documento-tecnico-bre-b-febrero-2026.pdf
# Fragmentos a recuperar por consulta
# BREB_RAG_TOP_K=6

# Si es true, FastAPI no arranca si falta SQLite poblado, JSON de productos o índice BRE-B
# STRICT_DATA_BOOTSTRAP=false

# API para Streamlit
ORCHESTRATOR_API_URL=http://127.0.0.1:8000

# --- Azure OpenAI (prioritario si están las tres primeras) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=tu-deployment
# Versión de la API REST de Azure; alternativa: OPENAI_API_VERSION
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- OpenAI directo (solo si NO usas Azure completo) ---
# OPENAI_API_KEY=
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
